# SSH Server Configuration (project-level)
# Copy this file to .env and fill in your server details
# This file is gitignored - credentials will not be committed

# Server naming pattern: SSH_SERVER_<NAME>_<FIELD>
# <NAME> must use underscores (e.g., UBUNTU_DEV, PROD_SERVER)

# Example: Ubuntu development server
# SSH_SERVER_UBUNTU_DEV_HOST=172.20.203.3
# SSH_SERVER_UBUNTU_DEV_USER=ubuntu
# SSH_SERVER_UBUNTU_DEV_PASSWORD=your_password
# SSH_SERVER_UBUNTU_DEV_PORT=22

# Example: Production server with SSH key
# SSH_SERVER_PROD_HOST=prod.example.com
# SSH_SERVER_PROD_USER=admin
# SSH_SERVER_PROD_KEYPATH=~/.ssh/id_rsa
# SSH_SERVER_PROD_PORT=22

# Example: Server behind bastion/jump host
# SSH_SERVER_BASTION_HOST=bastion.example.com
# SSH_SERVER_BASTION_USER=jumpuser
# SSH_SERVER_BASTION_KEYPATH=~/.ssh/bastion_key
#
# SSH_SERVER_INTERNAL_HOST=10.0.0.5
# SSH_SERVER_INTERNAL_USER=admin
# SSH_SERVER_INTERNAL_KEYPATH=~/.ssh/internal_key
# SSH_SERVER_INTERNAL_PROXYJUMP=bastion

# 仓库项目（外部克隆，不提交）
repository/*

# 测试工程（本地测试产物，不提交）
test_project/*

# oh-my-claudecode 运行时
.omc/

# Claude 会话锁文件
.claude/scheduled_tasks.lock

# Playwright 运行时产物（trace、截图等）
.claude/test-artifacts/
.playwright-mcp/
/test-results/
/seed.spec.ts

# IDE
.vscode/
.idea/
*.swp
*.swo

# 通知配置（含 SMTP 密码）
.claude/notify-config.json

# 环境文件
.env
.env.local

# 依赖
node_modules/
package-lock.json

# 日志
*.log

# 跟踪文件
.traces/

# 代码图谱索引
.codegraph/

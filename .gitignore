# 仓库项目（外部克隆，不提交）
repository/*
!repository/READEME.md

# 测试工程（本地测试产物，不提交）
test_project/*
!test_project/READEME.md
!test_project/templates/

# oh-my-claudecode 运行时
.omc/

# Claude 会话锁文件
.claude/scheduled_tasks.lock

# Playwright 运行时产物（trace、截图等）
.claude/test-artifacts/
.playwright-mcp/

# IDE
.vscode/
.idea/
*.swp
*.swo

# 环境文件
.env
.env.local

# 依赖
node_modules/

# 日志
*.log

# 跟踪文件
.traces/
